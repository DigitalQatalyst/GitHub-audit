# GitHub Personal Access Token (repo + read:org scopes recommended)
PAT=

# Default org/user filter for scans
AUDIT_ACCOUNT_FILTER=DigitalQatalyst

# Server port
PORT=3000

# Optional: protect dashboard with basic auth (leave empty to disable)
DASHBOARD_USER=
DASHBOARD_PASSWORD=

# Optional: enable scheduled daily audit (cron expression, default 6 AM UTC)
AUDIT_CRON=0 6 * * *

# Data directory for persisted scan results
DATA_DIR=./data

# Scan mode: fast | thorough
DEFAULT_SCAN_MODE=fast
