# GitHub Personal Access Token
# Classic PAT: enable repo + read:org scopes, authorize for DigitalQatalyst SSO if required
# Fine-grained PAT: grant access to DigitalQatalyst org and all repositories (or all needed repos)
PAT=

# Default org/user filter for scans
AUDIT_ACCOUNT_FILTER=DigitalQatalyst

# Server port
PORT=3000

# Optional: protect dashboard with basic auth (leave empty to disable)
DASHBOARD_USER=
DASHBOARD_PASSWORD=

# Optional: enable scheduled daily audit (cron expression, default 5 AM UTC = 8 AM Nairobi)
AUDIT_CRON=0 5 * * *

# Data directory for persisted scan results
DATA_DIR=./data

# Persist scan results to GitHub (used on Vercel so cron data survives redeploys)
AUDIT_STORAGE_REPO=DigitalQatalyst/GitHub-audit
AUDIT_STORAGE_PATH=data/latest.json

# Scan mode: fast | thorough
DEFAULT_SCAN_MODE=fast
